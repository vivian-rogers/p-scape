# data/ is heavy intermediate artifacts (OSM extracts, OSRM tile dirs,
# per-city HTML maps, the per-ray `d_route_m` cache). We commit ONLY the
# single-page explorer.html — the durable deploy artifact and the only
# reproducibility guarantee collaborators need to view the catalog. NPZs
# are regenerable from the scripts/rerun_*_sq.sh pipeline.
data/*
!data/explorer.html
!data/.gitkeep

.venv/
__pycache__/
*.pyc
.ipynb_checkpoints/
.ruff_cache/
.pytest_cache/
dist/
build/
*.egg-info/
.DS_Store
